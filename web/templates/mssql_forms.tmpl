<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>h3sync MSSQL表单管理</title>
  <link rel="stylesheet" href="/static/admin.css" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
  <script src="/static/admin.js"></script>
  <script>
    function safeSetVal(id, v) { const el = document.getElementById(id); if (el) el.value = v; }
    window.openBindModal = function(btn) {
      try {
        const d = btn.dataset;
        const form = document.getElementById('bindForm'); if (form) form.action = '/admin/mssql/forms/' + (d.schema || '') + '/bind';
        safeSetVal('bindName', d.name || '');
        safeSetVal('bindGroup', d.group || '');
        safeSetVal('bindRemark', d.remark || '');
        safeSetVal('bindMethod', d.method || 'MANUAL');
        safeSetVal('bindInterval', d.interval || '60');
        // NOTE: 根据方式切换周期输入框的启用状态
        var intervalInput = document.getElementById('bindInterval');
        if (intervalInput) intervalInput.disabled = ((d.method || 'MANUAL') !== 'AUTO');
        if (window.openModal) window.openModal('bindMask');
      } catch(e) { console.error(e); }
    };
    window.toggleIntervalInput = function(sel) {
      var intervalInput = document.getElementById('bindInterval');
      if (intervalInput) intervalInput.disabled = (sel.value !== 'AUTO');
    };
    window.openLibraryModal = function() { if (window.openModal) window.openModal('libraryMask'); };
  </script>
</head>
<body>
  <!-- Modal Top for reliability -->
  <div id="libraryMask" class="modal-overlay">
    <div class="modal-content">
      <div class="card-title"><span>MSSQL库路径配置</span><button onclick="closeModal('libraryMask')" style="background:none;border:none;cursor:pointer;font-size:2rem;color:var(--text-muted);line-height:1;">&times;</button></div>
      <form method="post" action="/admin/mssql/library">
        <div class="form-group"><label>备份文件根路径</label><input name="root_path" value="{{.rootPath}}" required /><p style="font-size:0.75rem; color:var(--text-muted); margin-top:4px;">系统将扫描该目录下的 .sql 文件进行增量或全量同步。</p></div>
        <div style="margin-top:24px; display:flex; justify-content:flex-end; gap:12px;"><button type="button" class="btn" onclick="closeModal('libraryMask')">取消</button><button type="submit" class="btn btn-primary">应用保存</button></div>
      </form>
    </div>
  </div>

  <div id="bindMask" class="modal-overlay">
    <div class="modal-content">
      <div class="card-title"><span>备份任务绑定</span><button onclick="closeModal('bindMask')" style="background:none;border:none;cursor:pointer;font-size:2rem;color:var(--text-muted);line-height:1;">&times;</button></div>
      <form method="post" id="bindForm">
        <div class="grid-cols-2">
          <div class="form-group"><label>业务显示名称</label><input name="display_name" id="bindName" required /></div>
          <div class="form-group"><label>业务分组</label><input name="group_name" id="bindGroup" /></div>
          <div class="form-group"><label>同步方式</label><select name="sync_method" id="bindMethod" onchange="toggleIntervalInput(this)"><option value="MANUAL">手动触发</option><option value="AUTO">自动定时</option></select></div>
          <div class="form-group"><label>同步周期 (分钟)</label><input type="number" name="sync_interval_minutes" id="bindInterval" value="60" min="1" disabled /><p style="font-size:0.7rem; color:var(--text-muted); margin-top:2px;">仅在自动定时模式下生效</p></div>
          <div class="form-group col-span-full"><label>数据备注 (AI 语义理解)</label><textarea name="chinese_remark" id="bindRemark" rows="2"></textarea></div>
        </div>
        <div style="margin-top:24px; display:flex; justify-content:flex-end; gap:12px;"><button type="button" class="btn" onclick="closeModal('bindMask')">取消</button><button type="submit" class="btn btn-primary">保存配置</button></div>
      </form>
    </div>
  </div>

  <div class="app-container">
    {{template "sidebar" .}}

    <div class="mobile-header">
      <div style="font-weight: 800; font-size: 1.2rem;">h3sync</div>
      <button class="menu-toggle"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
    </div>

    <main class="main-content">
      <div class="card" style="margin-bottom: 24px;">
        <div class="card-title">
          <span>MSSQL备份库管理</span>
          <div style="display:flex;gap:8px;">
            <button class="btn" onclick="openLibraryModal()">路径配置</button>
            <form method="post" action="/admin/mssql/discover"><button class="btn btn-primary" type="submit">扫描新表单</button></form>
          </div>
        </div>
        <div style="font-size:0.8125rem; color:var(--text-muted); margin-top:-8px;">
          路径: <code>{{if .rootPath}}{{.rootPath}}{{else}}暂未配置{{end}}</code> | 最后扫描: {{.libraryAt}}
        </div>
      </div>

      {{if .message}}<div class="card" style="background:#f0f9ff; border-color:#bae6fd; color:#0369a1; padding:12px 24px; margin-bottom:24px;">{{.message}}</div>{{end}}

      <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px;">
        {{range .groups}}<a href="#{{.ID | urlquery}}" style="text-decoration: none; color: var(--text-muted); background: #fff; border: 1px solid var(--border-color); padding: 4px 12px; border-radius: 20px; font-size: 0.8125rem;" onclick="focusGroup('{{.ID}}');return false;"># {{.Title}}</a>{{end}}
      </div>

      {{range .groups}}
      <details id="{{.ID}}" {{if eq $.focus .ID}}open{{end}} style="background:#fff; border:1px solid var(--border-color); border-radius:12px; margin-bottom:16px; box-shadow:var(--shadow);">
        <summary style="padding:16px; cursor:pointer; font-weight:700; display:flex; justify-content:space-between; align-items:center;">
          <div style="display:flex; align-items:center; gap:8px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
            <span>{{.Title}}</span>
            <span class="badge badge-info">{{len .Forms}}</span>
          </div>
          <form method="post" action="/admin/forms/groups/rename" onsubmit="event.stopPropagation();" style="display:flex; gap:8px;">
            <input type="hidden" name="source_type" value="MSSQL_BACKUP" />
            <input type="hidden" name="old_group_name" value="{{.Title}}" />
            <input name="new_group_name" placeholder="重命名" style="width:100px; height:30px; font-size:0.75rem;" />
            <button class="btn btn-sm">保存</button>
          </form>
        </summary>
        <div class="table-container">
          <table>
            <thead><tr><th>SchemaCode</th><th>原始表名</th><th>业务名称</th><th>同步方式</th><th>记录数</th><th>上一次同步</th><th>操作</th></tr></thead>
            <tbody>
              {{range .Forms}}
              <tr>
                <td><code>{{.SchemaCode}}</code></td>
                <td style="font-size:0.8125rem; color:var(--text-muted);">{{.SourceFullName}}</td>
                <td><strong>{{.DisplayName}}</strong></td>
                <td>
                  <span class="badge {{if eq .SyncMethod "AUTO"}}badge-success{{else}}badge-info{{end}}">{{.SyncMethodLabel}}</span>
                  {{if eq .SyncMethod "AUTO"}}<span style="font-size:0.7rem; color:var(--text-muted); display:block; margin-top:2px;">{{.SyncIntervalMinutes}}分钟/次</span>{{end}}
                </td>
                <td>{{.DataCount}}</td>
                <td style="font-size:0.75rem;">{{.LastSyncLabel}}</td>
                <td>
                  <div class="action-icon-group">
                    <button class="btn-icon" onclick="openBindModal(this)" data-schema="{{.SchemaCode}}" data-name="{{.DisplayName}}" data-group="{{.GroupName}}" data-remark="{{.ChineseRemark}}" data-method="{{.SyncMethod}}" data-interval="{{.SyncIntervalMinutes}}"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5Z"/></svg></button>
                    <a href="/admin/mssql/forms/{{.SchemaCode}}/data" class="btn-icon" title="查看数据"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/></svg></a>
                    <form method="post" action="/admin/mssql/forms/{{.SchemaCode}}/sync"><button class="btn-icon" type="submit" title="手动同步"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-3-6.7"/><polyline points="21 3 21 9 15 9"/></svg></button></form>
                    <form method="post" action="/admin/mssql/forms/{{.SchemaCode}}/delete" onsubmit="return confirm('警告：永久删除该 MSSQL 表单配置及所有已同步的数据。\n\n操作不可逆，确定删除？');"><button class="btn-icon danger" type="submit" title="删除表单"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/></svg></button></form>
                  </div>
                </td>
              </tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </details>
      {{end}}

      <div class="card" style="margin-top: 32px;">
        <h3 class="card-title">备份库同步审计</h3>
        <form class="grid-cols-2" style="grid-template-columns: 1fr 1fr auto; align-items: end; margin-bottom: 24px;" method="get">
          <div class="form-group"><label>状态</label><select name="log_status"><option value="">全部</option><option value="SUCCESS" {{if eq .logStatus "SUCCESS"}}selected{{end}}>成功</option><option value="FAILED" {{if eq .logStatus "FAILED"}}selected{{end}}>失败</option></select></div>
          <div class="form-group"><label>触发</label><select name="log_trigger"><option value="">全部</option><option value="AUTO" {{if eq .logTrigger "AUTO"}}selected{{end}}>自动</option><option value="MANUAL" {{if eq .logTrigger "MANUAL"}}selected{{end}}>手动</option></select></div>
          <button class="btn btn-primary" type="submit" style="margin-bottom:16px;">过滤</button>
        </form>
        <div class="table-container">
          <table>
            <thead><tr><th>任务名称</th><th>触发方式</th><th>执行状态</th><th>起止时间</th><th>记录数</th><th>详情</th></tr></thead>
            <tbody>
              {{range .logs}}
              <tr>
                <td><strong>{{.DisplayName}}</strong></td>
                <td>{{.TriggerLabel}}</td>
                <td><span class="badge {{if eq .Status "SUCCESS"}}badge-success{{else if eq .Status "RUNNING"}}badge-info{{else}}badge-error{{end}}">{{.StatusLabel}}</span></td>
                <td style="font-size:0.75rem;">{{.StartedLabel}} → {{.FinishedLabel}}</td>
                <td><span class="badge badge-info">{{.SyncedCount}}</span></td>
                <td style="font-size:0.75rem; color:var(--text-muted); max-width:200px; text-overflow:ellipsis; overflow:hidden;">{{.ErrorMessage}}</td>
              </tr>
              {{else}}
              <tr><td colspan="6" style="text-align:center; padding:40px; color:var(--text-muted);">暂无同步历史记录</td></tr>
              {{end}}
            </tbody>
          </table>
        </div>
        <div style="margin-top: 24px; display: flex; justify-content: space-between; align-items: center;">
          <div style="font-size: 0.8125rem; color: var(--text-muted);">共 {{.logTotal}} 条，第 {{.logPage}}/{{.logTotalPages}} 页</div>
          <div style="display: flex; gap: 4px;">{{range .logPages}}<a class="btn btn-sm {{if eq $.logPage .}}btn-primary{{end}}" href="/admin/mssql/forms?log_status={{$.logStatus}}&log_trigger={{$.logTrigger}}&log_page={{.}}">{{.}}</a>{{end}}</div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
