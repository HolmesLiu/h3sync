<!doctype html>
<html>
<head><meta charset="utf-8" /><title>h3sync forms</title></head>
<body>
  <h1>表单配置</h1>
  <p><a href="/admin">返回控制台</a></p>

  <h2>新增/更新表单</h2>
  <form method="post" action="/admin/forms">
    <input name="schema_code" placeholder="SchemaCode" required />
    <input name="display_name" placeholder="显示名称" required />
    <input name="chinese_remark" placeholder="中文备注" />
    <select name="sync_method"><option>AUTO</option><option>MANUAL</option></select>
    <select name="sync_mode"><option>INCREMENTAL</option><option>FULL</option></select>
    <input name="sync_interval_minutes" placeholder="周期(分钟)" value="30" />
    <label><input type="checkbox" name="is_enabled" checked />启用</label>
    <button type="submit">保存</button>
  </form>

  <h2>当前表单</h2>
  <table border="1" cellpadding="6">
    <tr><th>SchemaCode</th><th>名称</th><th>备注</th><th>同步方式</th><th>周期</th><th>操作</th></tr>
    {{range .forms}}
    <tr>
      <td>{{.SchemaCode}}</td>
      <td>{{.DisplayName}}</td>
      <td>{{.ChineseRemark}}</td>
      <td>{{.SyncMethod}}</td>
      <td>{{.SyncIntervalMinutes}} min</td>
      <td>
        <form style="display:inline" method="post" action="/admin/forms/{{.SchemaCode}}/sync">
          <button type="submit">手动同步</button>
        </form>
      </td>
    </tr>
    {{end}}
  </table>
</body>
</html>
