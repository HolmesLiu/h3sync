  <!-- Key Modal -->
  <div id="keyModalMask" class="modal-overlay">
    <div class="modal-content">
      <div class="card-title">
        <span>生成新访问凭证</span>
        <button onclick="closeModal('keyModalMask')" class="btn-close-large">&times;</button>
      </div>
      <form method="post" action="/admin/apikeys">
        <div class="grid-cols-2">
          <div class="form-group"><label>名称</label><input name="name" placeholder="凭证名称" required /></div>
          <div class="form-group"><label>用途备注</label><input name="remark" /></div>
          <div class="checkbox-group">
            <input type="checkbox" name="auto_expire" onchange="toggleExpireInput('expireInCreate', this)" />
            <span>设置有效期</span>
          </div>
          <div class="form-group"><label>有效期至</label><input type="datetime-local" id="expireInCreate" name="expires_at" disabled /></div>
        </div>
        <div class="col-span-full" style="margin-top:24px;">
           <label style="margin-bottom:12px; display:block; font-weight:700;">授权访问范围 (按组折叠)</label>
           <div style="max-height: 300px; overflow-y:auto; border:1px solid #e2e8f0; padding:4px; border-radius:12px; background:#fcfcfc;">
             {{range $gi, $group := .formGroups}}
             <details class="group-details" open>
               <summary style="display:flex; justify-content:space-between; align-items:center;">
                 <span>{{$group.Title}}</span>
                 <div style="display:flex; gap:4px;">
                   <button type="button" class="btn" style="padding: 2px 8px; font-size: 0.7rem;" onclick="toggleGroupChecks('g{{$gi}}', true); event.stopPropagation();">全选</button>
                   <button type="button" class="btn" style="padding: 2px 8px; font-size: 0.7rem;" onclick="toggleGroupChecks('g{{$gi}}', false); event.stopPropagation();">取消全部</button>
                 </div>
               </summary>
               <div class="perm-list" data-mode="create" data-group="g{{$gi}}">
                 {{range $group.Forms}}
                 <label class="perm-item">
                   <input type="checkbox" name="schema_codes" value="{{.SchemaCode}}" />
                   <span title="{{.DisplayName}}">{{.DisplayName}}</span>
                 </label>
                 {{end}}
               </div>
             </details>
             {{end}}
           </div>
        </div>
        <div style="margin-top:32px; display:flex; justify-content:flex-end; gap:12px;">
          <button type="button" class="btn" onclick="closeModal('keyModalMask')">取消</button>
          <button type="submit" class="btn btn-primary">立即生成</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="editModalMask" class="modal-overlay">
    <div class="modal-content">
      <div class="card-title">
        <span>凭证权限更正</span>
        <button onclick="closeModal('editModalMask')" class="btn-close-large">&times;</button>
      </div>
      <form id="editForm" method="post">
        <div class="grid-cols-2">
          <div class="form-group"><label>名称</label><input id="editName" name="name" required /></div>
          <div class="form-group"><label>备注</label><input id="editRemark" name="remark" /></div>
          <div class="form-group"><label>新有效期</label><input type="datetime-local" id="editExpireInput" name="expires_at" disabled /></div>
          <div class="checkbox-group">
            <input type="checkbox" id="editAutoExpire" name="auto_expire" onchange="toggleExpireInput('editExpireInput', this)" />
            <span>启用有效期</span>
          </div>
          
        </div>
        <div class="col-span-full" style="margin-top:24px;">
           <label style="margin-bottom:12px; display:block; font-weight:700;">调整授权范围</label>
           <div style="max-height: 300px; overflow-y:auto; border:1px solid #e2e8f0; padding:4px; border-radius:12px; background:#fcfcfc;">
             {{range $gi, $group := .formGroups}}
             <details class="group-details" open>
               <summary style="display:flex; justify-content:space-between; align-items:center;">
                 <span>{{$group.Title}}</span>
                 <div style="display:flex; gap:4px;">
                   <button type="button" class="btn" style="padding: 2px 8px; font-size: 0.7rem;" onclick="toggleGroupChecks('eg{{$gi}}', true); event.stopPropagation();">全选</button>
                   <button type="button" class="btn" style="padding: 2px 8px; font-size: 0.7rem;" onclick="toggleGroupChecks('eg{{$gi}}', false); event.stopPropagation();">取消全部</button>
                 </div>
               </summary>
               <div class="perm-list" data-mode="edit" data-group="eg{{$gi}}">
                 {{range $group.Forms}}
                 <label class="perm-item">
                   <input type="checkbox" name="schema_codes" value="{{.SchemaCode}}" />
                   <span title="{{.DisplayName}}">{{.DisplayName}}</span>
                 </label>
                 {{end}}
               </div>
             </details>
             {{end}}
           </div>
        </div>
        <div style="margin-top:32px; display:flex; justify-content:flex-end; gap:12px;">
          <button type="button" class="btn" onclick="closeModal('editModalMask')">取消</button>
          <button type="submit" class="btn btn-primary">确认保存</button>
        </div>
      </form>
    </div>
  </div>

  <div id="toast" style="position:fixed; bottom:30px; left:50%; transform:translateX(-50%); background:#1e293b; color:#fff; padding:12px 24px; border-radius:99px; font-size:0.875rem; opacity:0; transition:all 0.3s; pointer-events:none; z-index:1000; box-shadow:0 10px 15px -3px rgba(0,0,0,0.15);"></div>
  <script>initPermMap({{.permJSON}});</script>
</body>
</html>
