             {{range $gi, $group := .formGroups}}
             <details class="group-details" open>
               <summary>{{$group.Title}}</summary>
               <div class="perm-list" data-mode="edit" data-group="eg{{$gi}}">
                 {{range $group.Forms}}
                 <label class="perm-item">
                   <input type="checkbox" name="schema_codes" value="{{.SchemaCode}}" />
                   <span title="{{.DisplayName}}">{{.DisplayName}}</span>
                 </label>
                 {{end}}
               </div>
             </details>
             {{end}}
           </div>
        </div>
        <div style="margin-top:32px; display:flex; justify-content:flex-end; gap:12px;">
          <button type="button" class="btn" onclick="closeModal('editModalMask')">取消</button>
          <button type="submit" class="btn btn-primary">确认保存</button>
        </div>
      </form>
    </div>
  </div>

  <div id="toast" style="position:fixed; bottom:30px; left:50%; transform:translateX(-50%); background:#1e293b; color:#fff; padding:12px 24px; border-radius:99px; font-size:0.875rem; opacity:0; transition:all 0.3s; pointer-events:none; z-index:1000; box-shadow:0 10px 15px -3px rgba(0,0,0,0.15);"></div>
  <script>initPermMap({{.permJSON}});</script>
</body>
</html>
