  <style>
    /* 核心样式优化 */
    .btn-close-large {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 2.2rem;
      color: var(--text-muted);
      line-height: 1;
      padding: 0 12px;
      transition: all 0.2s;
    }
    .btn-close-large:hover { color: var(--primary); transform: scale(1.1); }

    .group-details {
      margin-bottom: 12px;
      border: 1px solid #eef2f6;
      border-radius: 8px;
      background: #fff;
      overflow: hidden;
    }
    .group-details summary {
      padding: 10px 16px;
      background: #f8fafc;
      cursor: pointer;
      font-weight: 700;
      color: var(--text-main);
      display: flex;
      justify-content: space-between;
      align-items: center;
      user-select: none;
      list-style: none; /* Hide default arrow */
    }
    .group-details summary::-webkit-details-marker { display: none; }
    .group-details summary::after {
      content: '▾';
      color: var(--text-muted);
      transition: transform 0.2s;
    }
    .group-details[open] summary::after { transform: rotate(180deg); }
    .group-details summary:hover { background: #f1f5f9; }

    .perm-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 8px;
      padding: 12px;
      background: #fff;
    }
    .perm-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 6px 10px;
      border-radius: 6px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .perm-item:hover { background: var(--bg-hover); }
    .perm-item input[type="checkbox"] {
      width: 16px;
      height: 16px;
      cursor: pointer;
      margin: 0;
      flex-shrink: 0;
    }
    .perm-item span {
      font-size: 0.8125rem;
      color: var(--text-main);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* 修复有效期选择框样式 */
    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 8px;
      white-space: nowrap; /* 核心修复：防止换行 */
      padding-top: 24px;
    }
    .checkbox-group input[type="checkbox"] {
      width: 16px !important; /* 核心修复：限制宽度 */
      height: 16px !important;
      cursor: pointer;
      margin: 0;
      flex-shrink: 0;
    }
    .checkbox-group span {
      font-size: 0.875rem;
      font-weight: 500;
    }

    .doc-section { background: #f8fafc; border: 1px solid var(--border-color); border-radius: 12px; padding: 24px; margin-top: 32px; }
    .doc-tabs { display: flex; gap: 16px; margin-bottom: 20px; border-bottom: 1px solid var(--border-color); }
    .doc-tab-btn { padding: 8px 16px; cursor: pointer; border: none; background: none; font-weight: 600; color: var(--text-muted); border-bottom: 2px solid transparent; transition: all 0.2s; }
    .doc-tab-btn.active { color: var(--primary); border-bottom-color: var(--primary); }
    .doc-content { display: none; }
    .doc-content.active { display: block; animation: fadeIn 0.3s; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
    #toast.show { opacity: 1; pointer-events: auto; }
  </style>
  <script>
    window.showToast = function(msg) {
      const t = document.getElementById('toast');
      if(t) {
        t.textContent = msg;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 2500);
      }
    };
    window.copyText = function(id) {
      const el = document.getElementById(id);
      if(!el) return;
      const text = el.innerText || el.textContent;
      navigator.clipboard.writeText(text).then(() => showToast('已成功复制到剪贴板'));
    };
    window.switchTab = function(tabId, btn) {
      document.querySelectorAll('.doc-tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.doc-content').forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(tabId).classList.add('active');
    };
    window.toggleExpireInput = function(inputId, cb) {
      const input = document.getElementById(inputId);
      if(input) input.disabled = !cb.checked;
    };

    let permMap = {};
    window.initPermMap = function(jsonStr) {
      try { permMap = JSON.parse(jsonStr || '{}'); } catch(e) { console.error(e); }
    };
    window.openEditModal = function(btn) {
      const id = btn.dataset.id;
      document.getElementById('editForm').action = '/admin/apikeys/'+id+'/update';
      document.getElementById('editName').value = btn.dataset.name || '';
      document.getElementById('editRemark').value = btn.dataset.remark || '';
      const expiry = btn.dataset.expires;
      const auto = document.getElementById('editAutoExpire');
      const input = document.getElementById('editExpireInput');
      if(expiry) { auto.checked = true; input.disabled = false; input.value = expiry; }
      else { auto.checked = false; input.disabled = true; input.value = ''; }
      
      document.querySelectorAll('.perm-list[data-mode="edit"] input').forEach(b => b.checked = false);
      (permMap[parseInt(id)] || permMap[id] || []).forEach(code => {
        const b = document.querySelector('.perm-list[data-mode="edit"] input[value="'+code+'"]');
        if(b) b.checked = true;
      });
      if(typeof openModal === 'function') openModal('editModalMask');
    };
  </script>
</head>
