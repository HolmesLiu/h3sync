                    <form method="post" action="/admin/apikeys/{{.ID}}/delete" onsubmit="return confirm('永久删除该 Key？');"><button class="btn-icon danger"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/></svg></button></form>
