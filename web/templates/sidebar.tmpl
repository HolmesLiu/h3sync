{{define "sidebar"}}
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header" style="display:flex; justify-content:space-between; align-items:center; width:100%;">
      <span class="sidebar-logo-text">h3sync</span>
      <button class="btn-icon" onclick="toggleSidebarDesktop()" style="background:none;border:none;color:white;cursor:pointer;padding:4px;" title="收起/展开菜单">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="{{if eq .navItem "dashboard"}}active{{end}}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        <span class="nav-text">控制台</span>
      </a>
      <a href="/admin/forms" class="{{if eq .navItem "forms"}}active{{end}}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        <span class="nav-text">H3表单管理</span>
      </a>
      <a href="/admin/mssql/forms" class="{{if eq .navItem "mssql_forms"}}active{{end}}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
        <span class="nav-text">MSSQL表单管理</span>
      </a>
      <a href="/admin/enterprise/forms" class="{{if eq .navItem "enterprise_forms"}}active{{end}}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16"/><path d="M6 18V7"/><path d="M10 18V7"/><path d="M14 18v-5"/><path d="M18 18V7"/><path d="M3 7l9-5 9 5"/></svg>
        <span class="nav-text">企业资料库</span>
      </a>
      <a href="/admin/apikeys" class="{{if eq .navItem "apikeys"}}active{{end}}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3L15.5 7.5z"/></svg>
        <span class="nav-text">API Key 管理</span>
      </a>
      <a href="/admin/users" class="{{if eq .navItem "users"}}active{{end}}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span class="nav-text">用户管理</span>
      </a>
      <a href="/admin/agent-gen" class="{{if eq .navItem "agent-gen"}}active{{end}}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/></svg>
        <span class="nav-text">Agent生成中心</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <form method="post" action="/admin/logout">
        <button type="submit" class="btn-logout" id="logoutBtn">
          <span class="nav-text">退出登录</span>
          <span class="logout-icon" style="display:none; font-size:1.2rem;">⎋</span>
        </button>
      </form>
    </div>
  </aside>

  <script>
    function toggleSidebarDesktop() {
      const root = document.documentElement;
      let isCollapsed = root.style.getPropertyValue('--sidebar-width') === '64px';

      if (!root.style.getPropertyValue('--sidebar-width')) {
        isCollapsed = localStorage.getItem('sidebarState') === 'collapsed';
      }

      const elementsToHide = document.querySelectorAll('.nav-text, .sidebar-logo-text');
      const logoutBtn = document.querySelector('.btn-logout');
      const logoutIcon = document.querySelector('.logout-icon');

      if (isCollapsed) {
        root.style.setProperty('--sidebar-width', '260px');
        elementsToHide.forEach(el => el.style.display = '');
        if (logoutBtn) logoutBtn.style.padding = '';
        if (logoutIcon) logoutIcon.style.display = 'none';
        localStorage.setItem('sidebarState', 'expanded');
      } else {
        root.style.setProperty('--sidebar-width', '64px');
        elementsToHide.forEach(el => el.style.display = 'none');
        if (logoutBtn) logoutBtn.style.padding = '12px 0';
        if (logoutIcon) logoutIcon.style.display = 'inline-block';
        localStorage.setItem('sidebarState', 'collapsed');
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => {
        const sidebar = document.querySelector('.sidebar');
        const main = document.querySelector('.main-content');
        if (sidebar) sidebar.style.transition = 'width 0.3s ease, transform 0.3s ease';
        if (main) main.style.transition = 'margin-left 0.3s ease, margin 0.3s ease, padding 0.3s ease';
      }, 50);

      if (localStorage.getItem('sidebarState') === 'collapsed' && window.innerWidth >= 1024) {
        const root = document.documentElement;
        root.style.setProperty('--sidebar-width', '64px');
        const elementsToHide = document.querySelectorAll('.nav-text, .sidebar-logo-text');
        elementsToHide.forEach(el => el.style.display = 'none');
        const logoutBtn = document.querySelector('.btn-logout');
        const logoutIcon = document.querySelector('.logout-icon');
        if (logoutBtn) logoutBtn.style.padding = '12px 0';
        if (logoutIcon) logoutIcon.style.display = 'inline-block';
      }
    });
  </script>
{{end}}
