<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>h3sync 管理后台登录</title>
  <link rel="stylesheet" href="/static/admin.css" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
  <style>
    body {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
    }
    .login-container {
      width: 100%;
      max-width: 420px;
      padding: 24px;
    }
    .login-box {
      background: #fff;
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }
    .login-header {
      text-align: center;
      margin-bottom: 32px;
    }
    .h3sync-logo {
      font-size: 2rem;
      font-weight: 800;
      color: #0f172a;
      letter-spacing: -0.05em;
    }
    .error-alert {
      background: #fef2f2;
      border: 1px solid #fee2e2;
      color: #dc2626;
      padding: 12px;
      border-radius: 8px;
      font-size: 0.8125rem;
      margin-bottom: 16px;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-box">
      <div class="login-header">
        <div class="h3sync-logo">h3sync</div>
        <p style="color: var(--text-muted); font-size: 0.875rem; margin-top: 8px;">瑞普生物数据同步管理后台</p>
      </div>

      {{if .error}}
      <div class="error-alert">
        {{.error}}
      </div>
      {{end}}

      <form method="post" action="/admin/login">
        <div class="form-group">
          <label>管理员账号</label>
          <input name="username" value="{{.username}}" placeholder="请输入用户名" required autofocus />
        </div>
        <div class="form-group" style="margin-top: 20px;">
          <label>登录密码</label>
          <input type="password" name="password" placeholder="请输入密码" required />
        </div>
        <div class="form-group" style="margin-top: 20px;">
          <label>验证码 {{.captchaQuestion}}</label>
          <input name="captcha" placeholder="请输入验证码答案" required />
        </div>
        <div style="margin-top: 32px;">
          <button type="submit" class="btn btn-primary" style="width: 100%; height: 48px; font-size: 1rem; justify-content: center;">
            安全登录
          </button>
        </div>
      </form>
    </div>
    <p style="text-align: center; color: #64748b; font-size: 0.75rem; margin-top: 24px;">
      &copy; 2026 h3sync 系统管理组件. All rights reserved.
    </p>
  </div>
</body>
</html>
