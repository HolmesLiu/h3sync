<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>h3sync 企业资料库</title>
  <link rel="stylesheet" href="/static/admin.css" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
  <script src="/static/admin.js"></script>
  <script>
    function safeSet(id, value) {
      var el = document.getElementById(id);
      if (el) el.value = value || '';
    }
    window.focusGroup = function(id) {
      var el = document.getElementById(id);
      if (el) {
        el.open = true;
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };
    window.openEditEnterpriseModal = function(btn) {
      var d = btn.dataset;
      var form = document.getElementById('editEnterpriseForm');
      if (form) form.action = '/admin/enterprise/forms/' + (d.schema || '') + '/update';
      safeSet('editDisplayName', d.name);
      safeSet('editGroupName', d.group);
      safeSet('editRemark', d.remark);
      if (window.openModal) window.openModal('editEnterpriseMask');
    };
    window.lockEnterpriseUpload = function(form) {
      if (!form || form.dataset.submitting === '1') return false;
      form.dataset.submitting = '1';
      var button = form.querySelector('button[type="submit"]');
      if (button) {
        button.disabled = true;
        button.textContent = '解析中...';
      }
      return true;
    };
  </script>
</head>
<body>
  <div id="uploadEnterpriseMask" class="modal-overlay">
    <div class="modal-content">
      <div class="card-title"><span>上传企业资料</span><button onclick="closeModal('uploadEnterpriseMask')" style="background:none;border:none;cursor:pointer;font-size:2rem;color:var(--text-muted);line-height:1;">&times;</button></div>
      <form method="post" action="/admin/enterprise/forms/upload" enctype="multipart/form-data" onsubmit="return lockEnterpriseUpload(this);">
        <div class="grid-cols-2">
          <div class="form-group"><label>表单名称</label><input name="display_name" required /></div>
          <div class="form-group"><label>资料分组</label><input name="group_name" list="enterprise-groups" placeholder="企业资料库" /></div>
          <div class="form-group col-span-full"><label>备注说明</label><textarea name="chinese_remark" rows="3" placeholder="填写该资料的业务说明，供 API 和后续 AI 客服理解语义"></textarea></div>
          <div class="form-group col-span-full"><label>上传文件</label><input type="file" name="file" accept=".csv,.txt,.xlsx,.xlsm,.xltx,.docx,.pdf,.doc" required /><p style="font-size:0.75rem; color:var(--text-muted); margin-top:6px;">支持 CSV、文本、Excel、DOCX、PDF。旧版 DOC 暂不解析。上传后系统会同步解析并建表，完成前不可继续上传下一份。</p></div>
        </div>
        <div style="margin-top:24px; display:flex; justify-content:flex-end; gap:12px;"><button type="button" class="btn" onclick="closeModal('uploadEnterpriseMask')">取消</button><button type="submit" class="btn btn-primary">上传并建表</button></div>
      </form>
    </div>
  </div>

  <div id="editEnterpriseMask" class="modal-overlay">
    <div class="modal-content">
      <div class="card-title"><span>编辑资料表</span><button onclick="closeModal('editEnterpriseMask')" style="background:none;border:none;cursor:pointer;font-size:2rem;color:var(--text-muted);line-height:1;">&times;</button></div>
      <form method="post" id="editEnterpriseForm">
        <div class="grid-cols-2">
          <div class="form-group"><label>表单名称</label><input id="editDisplayName" name="display_name" required /></div>
          <div class="form-group"><label>资料分组</label><input id="editGroupName" name="group_name" list="enterprise-groups" /></div>
          <div class="form-group col-span-full"><label>备注说明</label><textarea id="editRemark" name="chinese_remark" rows="3"></textarea></div>
        </div>
        <div style="margin-top:24px; display:flex; justify-content:flex-end; gap:12px;"><button type="button" class="btn" onclick="closeModal('editEnterpriseMask')">取消</button><button type="submit" class="btn btn-primary">保存</button></div>
      </form>
    </div>
  </div>

  <datalist id="enterprise-groups">
    {{range .groupNames}}<option value="{{.}}"></option>{{end}}
  </datalist>

  <div class="app-container">
    {{template "sidebar" .}}
    <div class="mobile-header">
      <div style="font-weight: 800; font-size: 1.2rem;">h3sync</div>
      <button class="menu-toggle"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
    </div>

    <main class="main-content">
      <div class="card" style="margin-bottom:24px;">
        <div class="card-title">
          <span>企业资料库</span>
          <button class="btn btn-primary" onclick="openModal('uploadEnterpriseMask')">上传资料并建表</button>
        </div>
        <div style="font-size:0.875rem; color:var(--text-muted); margin-top:-8px;">上传后的资料会直接生成可授权给 API Key 的业务表单，用于客服或 AI Agent 的知识底座。</div>
      </div>

      {{if .message}}<div class="card" style="background:#f0f9ff; border-color:#bae6fd; color:#0369a1; padding:12px 24px; margin-bottom:24px;">{{.message}}</div>{{end}}

      <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:24px;">
        {{range .groups}}<a href="#{{.ID | urlquery}}" style="text-decoration:none; color:var(--text-muted); background:#fff; border:1px solid var(--border-color); padding:4px 12px; border-radius:20px; font-size:0.8125rem;" onclick="focusGroup('{{.ID}}'); return false;"># {{.Title}}</a>{{end}}
      </div>

      {{range .groups}}
      <details id="{{.ID}}" {{if eq $.focus .ID}}open{{end}} style="background:#fff; border:1px solid var(--border-color); border-radius:12px; margin-bottom:16px; box-shadow:var(--shadow);">
        <summary style="padding:16px; cursor:pointer; font-weight:700; display:flex; justify-content:space-between; align-items:center;">
          <div style="display:flex; align-items:center; gap:8px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
            <span>{{.Title}}</span>
            <span class="badge badge-info">{{len .Forms}}</span>
          </div>
          <form method="post" action="/admin/forms/groups/rename" onsubmit="event.stopPropagation();" style="display:flex; gap:8px;">
            <input type="hidden" name="source_type" value="ENTERPRISE_LIBRARY" />
            <input type="hidden" name="old_group_name" value="{{.Title}}" />
            <input name="new_group_name" placeholder="重命名" style="width:120px; height:30px; font-size:0.75rem;" />
            <button class="btn btn-sm">保存</button>
          </form>
        </summary>
        <div class="table-container">
          <table>
            <thead><tr><th>表单</th><th>来源文件</th><th>状态</th><th>记录数</th><th>最后解析</th><th>备注</th><th>操作</th></tr></thead>
            <tbody>
              {{range .Forms}}
              <tr>
                <td><div style="font-weight:700;">{{.DisplayTitle}}</div><div style="font-size:0.75rem; color:var(--text-muted);"><code>{{.SchemaCode}}</code></div></td>
                <td><div>{{.SourceFilename}}</div>{{if .SheetName}}<div style="font-size:0.75rem; color:var(--text-muted);">Sheet: {{.SheetName}}</div>{{end}}<div style="font-size:0.75rem; color:var(--text-muted);">{{.FileExt}} / {{.FileSize}} bytes</div></td>
                <td><span class="badge {{if eq .ParseStatus "READY"}}badge-success{{else if eq .ParseStatus "PROCESSING"}}badge-info{{else}}badge-error{{end}}">{{.StatusLabel}}</span><div style="font-size:0.75rem; color:var(--text-muted); margin-top:4px;">{{.ParseMessage}}</div></td>
                <td>{{.DataCount}}</td>
                <td style="font-size:0.75rem;">{{.ParsedLabel}}</td>
                <td style="font-size:0.8125rem; color:var(--text-muted); max-width:240px;">{{.ChineseRemark}}</td>
                <td>
                  <div class="action-icon-group">
                    <a href="/admin/enterprise/forms/{{.SchemaCode}}/data" class="btn-icon" title="查看内容"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/></svg></a>
                    <button class="btn-icon" type="button" onclick="openEditEnterpriseModal(this)" data-schema="{{.SchemaCode}}" data-name="{{.DisplayName}}" data-group="{{.GroupName}}" data-remark="{{.ChineseRemark}}" title="编辑表单"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5Z"/></svg></button>
                    <form method="post" action="/admin/enterprise/forms/{{.SchemaCode}}/delete" onsubmit="return confirm('确定删除该资料表及其全部已解析内容？');"><button class="btn-icon danger" type="submit" title="删除表单"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/></svg></button></form>
                  </div>
                </td>
              </tr>
              {{end}}
            </tbody>
          </table>
        </div>
      </details>
      {{end}}
    </main>
  </div>
</body>
</html>
